  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "autoprefixer": "10.4.21",
    "postcss": "8.5.8",
    "tailwindcss": "3.4.17",
    "typescript": "5.9.3"
  }
